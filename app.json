{
  "expo": {
    "name": "FocusFlow",
    "slug": "focusflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#7F77DD"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.focusflow.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "FocusFlow uses the microphone for voice journal entries.",
        "NSPhotoLibraryUsageDescription": "FocusFlow uses photos for memory journal uploads."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7F77DD"
      },
      "package": "com.focusflow.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7F77DD",
          "sounds": []
        }
      ],
      [
        "expo-av",
        { "microphonePermission": "Allow FocusFlow to access your microphone for voice journals." }
      ]
    ],
    "scheme": "focusflow",
    "extra": {
      "supabaseUrl":     "YOUR_SUPABASE_URL",
      "supabaseAnonKey": "YOUR_SUPABASE_ANON_KEY",
      "eas": { "projectId": "YOUR_EAS_PROJECT_ID" }
    }
  }
}
